# Server port (default: 3000)
PORT=3000

# REQUIRED in production — secret for signing JWT tokens (min 32 chars)
JWT_SECRET=change-this-to-a-long-random-secret-in-production

# Optional JWT expiry (default: 7d)
# JWT_EXPIRES_IN=7d

# Default passwords for first-time database seed only
# ADMIN_DEFAULT_PASSWORD=your-secure-admin-password
# WRITER_DEFAULT_PASSWORD=your-secure-writer-password

# SQLite database file path is zarifbar.db in project root (default)
# For production at scale, consider migrating to PostgreSQL — see README
